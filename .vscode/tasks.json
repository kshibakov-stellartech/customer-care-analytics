{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AWS: Login",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lic",
        "aws sso login --profile ${input:awsProfile}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "awsProfile",
      "type": "pickString",
      "description": "Select AWS profile to login",
      "options": [
        "CustomerCareTeamAccess",
        "AnalyticsAccess"
      ],
      "default": "CustomerCareTeamAccess"
    }
  ]
}
